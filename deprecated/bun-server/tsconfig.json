{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "lib": ["ESNext"],
        "types": ["bun-types"],
        "declaration": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "exactOptionalPropertyTypes": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": false,
        "resolveJsonModule": true,
        "outDir": "./server/dist"
    }
}
