{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "strict": true,
        "importHelpers": false,
        "inlineSources": true,
        "noEmitOnError": true,
        "pretty": true,
        "module": "esnext",
        "noImplicitAny": true,
        "suppressImplicitAnyIndexErrors": false,
        "removeComments": false,
        "sourceMap": true,
        "lib": ["esnext", "dom"],
        "skipLibCheck": true,
        "outDir": "dist",
        "target": "esnext",
        "declaration": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "types": ["node"],
        "allowSyntheticDefaultImports": true,
        "paths": {
            "*": ["./src/*"]
        }
    },
    "files": ["src/index.ts"],
    "include": ["src/**/*.d.ts"]
}
