{
  "name": "mpen-npm-packages",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mnpenner/npm-packages.git"
  },
  "packageManager": "bun@1.3.6",
  "type": "module",
  "workspaces": {
    "packages": ["packages/*"],
    "catalog": {
      "react": "^19",
      "react-dom": "^19",
      "typescript": "^6",
      "eslint": "^10"
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "test": "run-p -c 'test:*'",
    "test:unit": "bun test --isolate --parallel"
  }
}
