{
  "name": "mpen-npm-packages",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mnpenner/npm-packages.git"
  },
  "packageManager": "bun@1.3.13",
  "type": "module",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@eslint/js": "^10",
      "react": "^19",
      "react-dom": "^19",
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "typescript": "^6",
      "eslint": "^10",
      "eslint-plugin-react-compiler": "^19.1.0-rc.2",
      "eslint-plugin-react-hooks": "^7",
      "eslint-plugin-react-refresh": "^0.5",
      "eslint-plugin-unused-imports": "^4",
      "globals": "^17",
      "tsdown": "^0.21",
      "typedoc": "^0.28",
      "npm-run-all": "^4",
      "typescript-eslint": "^8",
      "chalk": "^5",
      "vite": ">=7, <9",
      "@types/bun": "latest",
      "bun-types": "latest"
    }
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/bun": "catalog:",
    "chalk": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-compiler": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "globals": "catalog:",
    "npm-run-all": "catalog:",
    "prettier": "3.8.3",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "overrides": {
    "zod-validation-error": "^4"
  },
  "scripts": {
    "test": "run-p -c -s 'test:*'",
    "test:unit": "bun run --silent scripts/test.ts",
    "lint": "bun run --bun eslint --format ./scripts/eslint-relative-formatter.ts --",
    "typecheck": "bun scripts/typecheck.ts",
    "fix:lint": "bun scripts/eslint-fix.ts",
    "check-format": "bun run --bun prettier . --check",
    "fix:format": "bun run --bun prettier . --write",
    "fix": "bun scripts/fix.ts",
    "static-analysis": "run-p -c -s lint typecheck check-format",
    "check": "bun scripts/check.ts",
    "publish": "bun scripts/publish.ts"
  }
}
