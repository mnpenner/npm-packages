{
  "name": "@mpen/react-basic-inputs",
  "description": "React wrappers around native inputs with improved behavior.",
  "version": "0.5.4",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/react-basic-inputs.d.ts",
      "bun": "./src/bundle.ts",
      "import": "./dist/react-basic-inputs.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "bun run --bun vite",
    "build": "run-p 'build:*'",
    "build:libs": "bun run --bun vite build",
    "build:docs": "typedoc && hg addremove docs",
    "lint": "run-s 'lint:*'",
    "lint:ts": "bun run --bun tsc",
    "lint:es": "bun run --bun eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0 --fix",
    "preview": "bun run --bun vite preview",
    "_prepublishOnly": "bun run --bun build",
    "_publish": "npm publish --access=public",
    "bump": "npm version patch && bun run build && npm publish"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@mpen/is-type": "workspace:*",
    "bun-types": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "npm-run-all": "^4.1.5",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-use": "^17.5.0",
    "sass": "^1.77.2",
    "typedoc": "catalog:",
    "typedoc-plugin-missing-exports": "^3.0.0",
    "typescript": "catalog:",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^3.9.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "publishHash": {
    "hgChangesetId": "d98e94266bbc+",
    "sha256": "3c4891c21ba07dcf753dbbccffe32b30c7fc90bf8e6f095b99cf93be8690d05c"
  }
}
