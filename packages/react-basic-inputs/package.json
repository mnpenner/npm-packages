{
  "name": "@mnpenner/react-basic-inputs",
  "version": "0.1.1",
  "packageManager": "yarn@3.5.0",
  "exports": "./dist/bundle.cjs",
  "module": "./dist/bundle.mjs",
  "types": "./dist/bundle.d.ts",
  "type": "module",
  "files": [
    "./dist"
  ],
  "scripts": {
    "dev:build": "rollup -cw",
    "dev:serve": "serve -l tcp://0.0.0.0:8080",
    "dev": "run-p \"dev:**\"",
    "serve": "bun run serve.ts",
    "bundle:clean": "rimraf -g \"dist/*\"",
    "bundle:build": "rollup -c",
    "bundle": "run-s bundle:clean bundle:build",
    "patch": "npm version patch && VER=$(jq -r '.version' package.json) && hg ci -m \"Publish v$VER\" && hg tag \"v$VER\"",
    "release": "run-s bundle patch && npm publish && hg push"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.4",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-replace": "^5.0.2",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^11.1.3",
    "@types/eslint": "^8",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "bun-types": "^0.8.1",
    "eslint": "^8.38.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.5.0",
    "npm-run-all": "^4.1.5",
    "react": ">=17 <19",
    "react-dom": ">=17 <19",
    "react-use": "^17.4.0",
    "rimraf": "^5.0.0",
    "rollup": "^3.20.2",
    "serve": "^14.2.0",
    "ts-jest": "^29.1.0",
    "tslib": "^2.5.0",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "react": ">=17 <19",
    "react-dom": ">=17 <19"
  }
}
