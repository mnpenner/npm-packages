{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/bundle.ts"],
  "out": "docs",
  "basePath": ".",
  "plugin": ["typedoc-plugin-missing-exports"],
  "excludeExternals": true,
  "skipErrorChecking": true,
  // https://github.com/TypeStrong/TypeDoc/issues/2109
  "kindSortOrder": ["Function","Class","Method","Interface","TypeAlias","Module"],
  "sourceLinkTemplate": "https://github.com/mnpenner/npm-packages/blob/main/packages/react-basic-inputs/{path}#L{line}"
}
