{
  "name": "@mpen/uri-template",
  "version": "0.1.12",
  "packageManager": "bun",
  "type": "module",
  "exports": {
    ".": "./dist/bundle.js",
    "./package.json": "./package.json"
  },
  "files": [
    "./dist"
  ],
  "devDependencies": {
    "@types/bun": "catalog:",
    "bun-types": "catalog:",
    "chalk": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=10"
  },
  "license": "MIT",
  "scripts": {
    "dev": "bun run --hot src/dev.ts",
    "build": "tsdown",
    "patch": "npm version patch && VER=$(jq -r '.version' package.json) && hg ci -m \"Publish v$VER\" && hg tag \"v$VER\"",
    "release": "bun run build && bun run patch && npm publish && hg push"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/bundle.js",
  "module": "./dist/bundle.js",
  "types": "./dist/bundle.d.ts"
}
