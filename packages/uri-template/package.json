{
  "name": "@mpen/uri-template",
  "description": "RFC 6570 URI template expansion and matching utilities.",
  "version": "0.1.16",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnpenner/npm-packages.git",
    "directory": "packages/uri-template"
  },
  "homepage": "https://github.com/mnpenner/npm-packages/tree/main/packages/uri-template",
  "packageManager": "bun",
  "type": "module",
  "exports": {
    ".": "./dist/bundle.js",
    "./package.json": "./package.json"
  },
  "files": [
    "./dist"
  ],
  "devDependencies": {
    "@types/bun": "catalog:",
    "bun-types": "catalog:",
    "chalk": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=10"
  },
  "license": "MIT",
  "scripts": {
    "dev": "bun run --hot src/dev.ts",
    "build": "tsdown",
    "patch": "npm version patch && VER=$(jq -r '.version' package.json) && hg ci -m \"Publish v$VER\" && hg tag \"v$VER\"",
    "release": "bun run build && bun run patch && npm publish && hg push"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/bundle.js",
  "module": "./dist/bundle.js",
  "types": "./dist/bundle.d.ts",
  "publishHash": {
    "hgChangesetId": "d98e94266bbc+",
    "sha256": "a58c9ce3301c7f454fead8f8f4721e2836c78a6e9f2b2fc0dc2c38caea8c22d9"
  }
}
