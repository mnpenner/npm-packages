{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "strict": true,
        "noCheck": true,
        "importHelpers": false,
        "inlineSources": true,
        "noEmitOnError": true,
        "pretty": true,
        "module": "ES6",
        "noImplicitAny": true,
        "suppressImplicitAnyIndexErrors": false,
        "removeComments": true,
        "sourceMap": true,
        "lib": ["es2018", "dom"],
        "skipLibCheck": true,
        "outDir": "dist",
        "target": "es2018",
        "declaration": true,
        "resolveJsonModule": false,
        "jsx": "react",
        "moduleResolution": "bundler",
        "types": ["node"]
    },
    "files": ["src/index.tsx"],
    "include": ["src/types/**/*.d.ts"],
    "exclude": ["node_modules"]
}
