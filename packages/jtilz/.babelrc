{
    "plugins": [
        "transform-function-bind"
    ],
    "env": {
        "node": {
            "presets": [
                [
                    "env",
                    {
                        "targets": {
                            "node": 6
                        }
                    }
                ]
            ]
        },
        "browser": {
            "presets": [
                [
                    "env",
                    {
                        "targets": {
                            "browsers": [
                                "> 1%",
                                "last 2 Firefox versions",
                                "last 2 Chrome versions",
                                "last 2 Edge versions",
                                "last 2 Safari versions",
                                "Firefox ESR",
                                "IE >= 8"
                            ]
                        }
                    }
                ]
            ]
        }
    }
}
