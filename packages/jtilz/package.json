{
  "name": "jtilz",
  "description": "Utility library for Node.js and Browser",
  "version": "0.4.1",
  "author": "Mark Penner <npm@mpen.ca>",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.6",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run --bun tsdown",
    "dev": "bun run --bun tsdown --watch",
    "test": "bun test src",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun run --bun eslint .",
    "fix:lint": "bun run --bun eslint . --fix"
  },
  "devDependencies": {
    "@types/node": "^22",
    "bun-types": "^1.3.13",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "hg",
    "url": "https://bitbucket.org/mnpenner/jtilz"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@mpen/is-type": "workspace:*"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./node": "./dist/node.mjs",
    "./web": "./dist/web.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts"
}
