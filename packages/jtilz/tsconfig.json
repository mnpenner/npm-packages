{
  "compilerOptions": {
    "strict": true,
    "removeComments": false,
    "preserveConstEnums": false,
    "sourceMap": true,
    "noEmitOnError": true,
    "pretty": true,
    "outDir": "dist",
    "target": "es5",
    "downlevelIteration": true,
    "lib": ["es2017", "dom"]
  },
  "include": [
    "src/**/*"
  ]
}