{
  "name": "onemig",
  "version": "0.2.3",
  "license": "UNLICENSED",
  "private": true,
  "bin": "src/main.js",
  "devDependencies": {
    "@sinclair/typebox-codegen": "^0.8.13",
    "@types/inflection": "^1.5.28",
    "@types/js-yaml": "^4.0.0",
    "@types/lodash": "^4.14.172",
    "@types/node": "^14.14.34",
    "@types/tar-stream": "^2.2.0",
    "bun-types": "^1.0.15",
    "cross-env": "^7.0.3",
    "dotenv": "^8.2.0",
    "esbuild": "^0.12.26",
    "ts-json-schema-generator": "^0.84.0",
    "typescript": "^4.1.3",
    "typescript-json-schema": "^0.48.0"
  },
  "dependencies": {
    "@mnpenner/is-type": "^0.1.7",
    "@sinclair/typebox": "^0.31.28",
    "chalk": "^4.1.0",
    "cli-api": "^0.1.0",
    "cli-highlight": "^2.1.10",
    "csv-parse": "^4.15.1",
    "inflection": "^1.13.1",
    "js-yaml": "^4.0.0",
    "json5": "^2.2.0",
    "lodash": "^4.17.21",
    "mysql3": "^0.5.13",
    "ora": "^5.3.0",
    "string-width": "^4.2.0",
    "tar-stream": "^2.2.0",
    "tslib": "^2.1.0"
  },
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --outfile=dist/onemig.js --platform=node --target=node14",
    "dev": "esbuild src/main.ts --bundle --outfile=dist/onemig.js --platform=node --sourcemap --watch",
    "exec": "node -r dotenv/config --enable-source-maps --max-old-space-size=16384 dist/onemig.js",
    "_run": "cross-env BABEL_ENV=development babel-node --max_old_space_size=10000 --extensions \".ts\" src/main.ts",
    "_tsdecls": "tsc --emitDeclarationOnly",
    "_lint": "tsc --noEmit",
    "_clean": "rm -rf dist yarn-error.log",
    "_build": "cross-env BABEL_ENV=production rollup -c",
    "devold": "cross-env BABEL_ENV=development rollup -cw",
    "_verbump": "npm version minor",
    "_publish": "pnpm run build && cd dist && pnpm publish --ignore-scripts"
  }
}
