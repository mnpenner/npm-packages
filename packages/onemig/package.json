{
    "name": "onemig",
    "version": "0.2.1",
    "license": "UNLICENSED",
    "private": true,
    "devDependencies": {
        "@babel/cli": "^7.12.13",
        "@babel/core": "^7.12.13",
        "@babel/node": "^7.12.13",
        "@babel/preset-env": "^7.12.13",
        "@babel/preset-typescript": "^7.12.13",
        "@mpen/rollup-preset-tsapp": "link:../rollup-plugins/packages/rollup-preset-tsapp",
        "@rollup/plugin-babel": "^5.2.3",
        "@rollup/plugin-commonjs": "^17.1.0",
        "@rollup/plugin-json": "^4.1.0",
        "@rollup/plugin-node-resolve": "^11.1.1",
        "@types/js-yaml": "^4.0.0",
        "@types/node": "^14.14.25",
        "@types/tar-stream": "^2.2.0",
        "builtin-modules": "^3.2.0",
        "clap": "../clap",
        "cross-env": "^7.0.3",
        "dotenv": "^8.2.0",
        "rollup": "^2.38.5",
        "rollup-plugin-node-externals": "^2.2.0",
        "ts-json-schema-generator": "^0.84.0",
        "typescript": "^4.1.3",
        "typescript-json-schema": "^0.48.0"
    },
    "dependencies": {
        "chalk": "^4.1.0",
        "cli-highlight": "^2.1.10",
        "csv-parse": "^4.15.1",
        "js-yaml": "^4.0.0",
        "mysql3": "^0.5.13",
        "ora": "^5.3.0",
        "string-width": "^4.2.0",
        "tar-stream": "^2.2.0"
    },
    "engines": {
        "node": ">=12"
    },
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "_run": "cross-env BABEL_ENV=development babel-node --max_old_space_size=10000 --extensions \".ts\" src/main.ts",
        "tsdecls": "tsc --emitDeclarationOnly",
        "lint": "tsc --noEmit",
        "clean": "rm -rf dist yarn-error.log",
        "build": "cross-env BABEL_ENV=production rollup -c",
        "dev": "cross-env BABEL_ENV=development rollup -cw",
        "exec": "node -r dotenv/config --enable-source-maps --max-old-space-size=16384 dist/main.js",
        "verbump": "npm version minor",
        "publish": "pnpm run build && cd dist && pnpm publish --ignore-scripts"
    }
}
