{
    "plugins": [
        "@babel/plugin-proposal-function-bind",
        "@babel/plugin-syntax-dynamic-import",
        ["@babel/plugin-proposal-decorators", { "legacy": true }]
    ],
    "presets": [
        [
            "@babel/preset-env",
            {
                "targets": {
                    "node": "current"
                },
                "exclude": [
                    "proposal-async-generator-functions",
                    "transform-async-to-generator"
                ]
            }
        ]
    ],
    "compact": false,
    "sourceMaps": "inline"
}
