{
    "compilerOptions": {
        "strict": true,
        "inlineSources": false,
        "noEmitOnError": false,
        "pretty": true,
        "module": "commonjs",
        "noImplicitAny": true,
        "suppressImplicitAnyIndexErrors": false,
        "removeComments": true,
        "preserveConstEnums": false,
        "sourceMap": false,
        "lib": ["esnext"],
        "skipLibCheck": true,
        "outDir": "dist",
        "target": "ES2020",
        "declaration": false,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "moduleResolution": "node",
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "rootDir": ".",
        "importHelpers": true,
        "incremental": true,
//        "tsBuildInfoFile": ".tsbuildinfo.json"
    },
    "files": [
        "./src/main.ts"
    ],
    "include": [
        "src/**/*.d.ts"
    ]
}
