      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "author": "Mark Penner <npm@mpen.ca>",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "typescript": "^5.8.2",
    "mitata": "^1.0.34",
    "tsdown": "^0.15.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mnpenner/ouid"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.0"
  },
