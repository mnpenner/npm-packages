{
  "name": "@mpen/logger",
  "description": "Lightweight logging utilities.",
  "version": "0.1.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnpenner/npm-packages.git",
    "directory": "packages/logger"
  },
  "license": "MIT",
  "author": "Mark Penner <npm@mpen.ca>",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser.js",
    "./json": "./dist/json.js",
    "./terminal": "./dist/terminal.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@mpen/picocolors": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "bun run --bun tsdown",
    "example:browser": "bun examples/browser/server.ts",
    "example:json": "bun examples/json-logger.ts",
    "example:terminal": "bun examples/terminal-logger.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun run test"
  },
  "publishConfig": {
    "access": "public"
  }
}
