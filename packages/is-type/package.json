{
  "name": "@mpen/is-type",
  "version": "0.2.0",
  "packageManager": "bun@1.1.23",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run --bun tsdown",
    "dev": "bun run --bun tsdown --watch",
    "test": "bun test src",
    "patch": "npm version patch && VER=$(jq -r '.version' package.json) && hg ci -m \"Publish v$VER\" && hg tag \"v$VER\"",
    "all": "run-p build test docs",
    "docs": "typedoc src/index.ts && hg addremove docs",
    "push": "hg pushall",
    "release": "run-s all patch && npm publish --access=public && hg pushall"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "bun-types": "^1.3.13",
    "npm-run-all": "catalog:",
    "tsdown": "catalog:",
    "tslib": "^2.4.1",
    "typedoc": "catalog:",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mnpenner/npm-packages",
    "directory": "packages/is-type"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  }
}
