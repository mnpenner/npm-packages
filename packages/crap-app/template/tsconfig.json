{
    "compilerOptions": {
        "strict": true,
        "noCheck": true,
        "importHelpers": false,
        "inlineSources": true,
        "noEmitOnError": true,
        "pretty": true,
        "module": "esnext",
        "noImplicitAny": true,
        "suppressImplicitAnyIndexErrors": false,
        "removeComments": false,
        "sourceMap": true,
        "lib": ["es2018", "dom"],
        "skipLibCheck": false,
        "outDir": "dist",
        "target": "es2018",
        "declaration": false,
        "resolveJsonModule": false,
        "jsx": "preserve",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "noEmit": true
    },
    "files": ["src/index.tsx"],
    "include": ["src/**/*.d.ts"]
}
