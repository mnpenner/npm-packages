{
  "name": "cli-api",
  "version": "0.3.0",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/eslint": "^8.56.12",
    "@types/node": "^12.20.55",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsdown": "^0.16.8",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.42.0"
  },
  "dependencies": {
    "@types/js-yaml": "^3.12.10",
    "chalk": "^5.6.2",
    "js-yaml": "^3.14.2",
    "mysql3": "workspace:*",
    "ora": "^4.1.1",
    "string-width": "^8.2.0",
    "tslib": "^2.8.1"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "scripts": {
    "build": "bun run --bun tsdown",
    "dev": "tsdown --watch",
    "test:tsc": "tsc --noEmit && echo \"tsc: no errors\"",
    "test:bun": "bun test",
    "test": "bun run --parallel 'test:*'",
    "lint": "bun run --bun eslint --fix --",
    "prepublishOnly": "bun run --parallel build test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mnpenner/node-cli-api.git"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs"
}
