{
    "name": "cli-api",
    "version": "0.2.0",
    "license": "UNLICENSED",
    "private": false,
    "type": "module",
    "types": "./dist/index.d.mts",
    "files": [
        "dist",
        "README.md"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.mts"
        }
    },
    "devDependencies": {
        "@types/bun": "^1.2.21",
        "@types/eslint": "^8.56.12",
        "@types/node": "^12.20.55",
        "@typescript-eslint/eslint-plugin": "^8.42.0",
        "eslint": "^8.57.1",
        "eslint-plugin-unused-imports": "^4.2.0",
        "tsdown": "^0.16.6",
        "typescript": "^5.9.3",
        "typescript-json-schema": "^0.42.0"
    },
    "dependencies": {
        "@types/js-yaml": "^3.12.10",
        "chalk": "^5.6.2",
        "js-yaml": "^3.14.1",
        "mysql3": "^0.4.16",
        "ora": "^4.1.1",
        "string-width": "^8.2.0",
        "tslib": "^2.8.1"
    },
    "engines": {
        "bun": ">=1.2"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test:tsc": "tsc --noEmit && echo \"tsc: no errors\"",
        "test:bun": "bun test",
        "test": "bun run test:tsc && bun run test:bun",
        "lint": "bun run --bun eslint --fix --"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/mnpenner/node-cli-api.git"
    }
}
