{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "rootDir": "../../",
        "outDir": "./dist",
        "lib": ["ESNext", "DOM"],
        "types": ["bun-types"],
        "exactOptionalPropertyTypes": true
    },
    "include": ["src/**/*.ts", "examples/**/*.ts"],
    "exclude": ["dist", "node_modules"]
}
