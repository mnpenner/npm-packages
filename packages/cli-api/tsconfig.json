{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationDir": "./dist",
        "emitDeclarationOnly": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "lib": ["ESNext"],
        "types": ["bun-types"],
        "outDir": "./dist"
    },
    "files": [
        "src/index.ts"
    ],
    "include": [
        "src/**/*.d.ts"
    ]
}
