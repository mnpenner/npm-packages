{
    "compilerOptions": {
        "strict": true,
        "importHelpers": false,
        "inlineSources": false,
        "noEmitOnError": true,
        "pretty": true,
        "module": "ESNext",
        "target": "ESNext",
        "lib": ["ESNext"],
        "noImplicitAny": true,
        "suppressImplicitAnyIndexErrors": false,
        "removeComments": false,
        "preserveConstEnums": true,
        "sourceMap": false,
        "skipLibCheck": true,
        "exactOptionalPropertyTypes": true,
        "outDir": "dist",
        "declaration": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,
        "baseUrl": ".",
        "paths": {
            "*": ["src/*"]
        },
        "types": ["bun-types"],
    },
    "files": [
        "src/dev.ts",
        "src/bundle.ts",
    ]
}
