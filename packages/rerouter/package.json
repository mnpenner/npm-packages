{
    "private": true,
    "packageManager": "bun@1.3.6",
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/bun": "latest",
        "eslint": "^9.39.2",
        "eslint-plugin-unused-imports": "^4.3.0",
        "globals": "^17.0.0",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.52.0"
    },
    "scripts": {
        "build:react-router": "bun run --cwd packages/react-router build",
        "build:server-router": "bun run --cwd packages/server-router build",
        "build:http-helpers": "bun run --cwd packages/http-helpers build",
        "build": "run-s build:react-router build:server-router build:http-helpers",
        "gen:react-router": "bun run --cwd packages/react-router gen",
        "gen:server-router": "bun run --cwd packages/server-router gen",
        "gen": "run-s gen:react-router gen:server-router",
        "test:types": "tsc -b tsconfig.json",
        "test:impl": "bun test packages/server-router packages/react-router packages/http-helpers",
        "test:all-impl": "bun test packages/",
        "test:gen": "run-s gen test:impl",
        "test": "run-s test:types test:gen",
        "lint": "bun run --bun eslint --fix --"
    },
    "dependencies": {
        "maxmind": "^5.0.3"
    }
}
