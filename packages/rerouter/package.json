{
  "name": "@mpen/rerouter",
  "description": "Lightweight type-safe router for React with URL helper generation.",
  "version": "0.3.1",
  "exports": {
    ".": "./dist/index.js",
    "./bin": "./dist/bin.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "rerouter": "./dist/bin.js"
  },
  "type": "module",
  "dependencies": {
    "@mpen/classcat": "workspace:*",
    "@mpen/ts-types": "workspace:*",
    "path-to-regexp": "^8.3.0"
  },
  "peerDependencies": {
    "react": "^19",
    "typescript": "^5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "react-dom": "^19.2.3",
    "tsdown": "catalog:"
  },
  "scripts": {
    "build": "tsdown",
    "gen": "bun cli/bin.ts ./examples/routes.ts -w -p",
    "serve": "bun --hot examples/index.html",
    "dev": "bun run --sequential gen serve",
    "prod": "bun run gen && bun build --production --splitting examples/index.html --outdir examples/dist && bun examples/server/serve-dist.ts"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "inlinedDependencies": {
    "prettier": "3.8.3",
    "process": "0.11.10"
  }
}
