{
  "name": "@mpen/rerouter",
  "version": "0.2.0",
  "exports": {
    ".": "./dist/index.js",
    "./bin": "./dist/bin.js",
    "./hooks": "./dist/hooks.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "rerouter": "./dist/bin.js"
  },
  "type": "module",
  "dependencies": {
    "@mpen/classcat": "workspace:*",
    "path-to-regexp": "^8.3.0"
  },
  "peerDependencies": {
    "react": "^19",
    "typescript": "^5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "react-dom": "^19.2.3",
    "tsdown": "catalog:"
  },
  "scripts": {
    "build": "tsdown",
    "gen": "bun src/bin.ts ./examples/routes.ts -w",
    "serve": "bun --hot examples/index.html",
    "dev": "bun run --sequential gen serve"
  },
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js"
