{
  "devDependencies": {
    "@types/bun": "latest",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "private": true,
  "scripts": {
    "build:react-router": "bun run --cwd ../react-router build",
    "build:server-router": "bun run --cwd ../server-router build",
    "build:http-helpers": "bun run --cwd ../http-helpers build",
    "build": "run-s build:react-router build:server-router build:http-helpers",
    "gen:react-router": "bun run --cwd ../react-router gen",
    "gen:server-router": "bun run --cwd ../server-router gen",
    "gen": "run-s gen:react-router gen:server-router",
    "test:types": "tsc -b tsconfig.json",
    "test:impl": "bun test ../server-router ../react-router ../http-helpers",
    "test:all-impl": "bun test ../server-router ../react-router ../http-helpers experimental/",
    "test:gen": "run-s gen test:impl",
    "test": "run-s test:types test:gen",
    "lint": "bun run --bun eslint --fix --"
  },
  "type": "module",
  "workspaces": [
    "experimental/*"
  ],
  "name": "@mpen/rerouter",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@mpen/uri-template": "workspace:*"
  }
}
