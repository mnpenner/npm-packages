{
    "private": true,
    "packageManager": "bun",
    "workspaces": [
        "packages/*"
    ],
    "type": "module",
    "devDependencies": {
        "@types/bun": "latest",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3"
    },
    "scripts": {
        "build:react-router": "bun run --cwd packages/react-router build",
        "build:server-router": "bun run --cwd packages/server-router build",
        "build": "run-s build:react-router build:server-router",
        "gen:react-router": "bun run --cwd packages/react-router gen",
        "gen:server-router": "bun run --cwd packages/server-router gen",
        "gen": "run-s gen:react-router gen:server-router",
        "test:types": "tsc -b tsconfig.json",
        "test:impl": "bun test packages/",
        "test:gen": "run-s gen test:impl",
        "test": "run-s test:types test:gen"
    }
}
