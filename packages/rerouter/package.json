{
    "name": "@mpen/rerouter",
    "version": "0.1.9",
    "packageManager": "bun",
    "workspaces": [
        "packages/*"
    ],
    "exports": "./dist/bundle.cjs",
    "module": "./dist/bundle.mjs",
    "types": "./dist/bundle.d.ts",
    "files": [
        "./dist"
    ],
    "type": "module",
    "devDependencies": {
        "@rollup/plugin-commonjs": "^25.0.4",
        "@rollup/plugin-node-resolve": "^15.2.1",
        "@rollup/plugin-replace": "^5.0.2",
        "@rollup/plugin-terser": "^0.4.3",
        "@rollup/plugin-typescript": "^11.1.3",
        "bun-types": "^1.3.3",
        "chalk": "^5.3.0",
        "npm-run-all": "^4.1.5",
        "rimraf": "^5.0.1",
        "rollup": "^3.29.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2"
    },
    "engines": {
        "node": ">=10"
    },
    "license": "MIT",
    "scripts": {
        "test:tsc": "tsc --noEmit -p packages/server-router/tsconfig.json",
        "test:bun": "bun test",
        "test": "run-p 'test:*'",
        "dev": "bun run --hot packages/uri-template/src/dev.ts",
        "bundle:clean": "rimraf -g \"dist/*\"",
        "bundle:build": "rollup -c",
        "bundle": "run-s bundle:clean bundle:build",
        "patch": "npm version patch && VER=$(jq -r '.version' package.json) && hg ci -m \"Publish v$VER\" && hg tag \"v$VER\"",
        "release": "run-s bundle patch && npm publish && hg push"
    },
    "dependencies": {
        "js-serialize": "^0.7.0",
        "neverject": "^0.2.3",
        "path-to-regexp": "^8.3.0",
        "urlpattern-polyfill": "^10.1.0",
        "zod": "^4.1.13"
    }
}
