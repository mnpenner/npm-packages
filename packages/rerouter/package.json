{
  "name": "@mpen/rerouter",
  "description": "Lightweight type-safe router for React with URL helper generation.",
  "version": "0.4.0",
  "exports": {
    ".": "./dist/index.js",
    "./bin": "./dist/bin.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "rerouter": "./dist/bin.js"
  },
  "type": "module",
  "dependencies": {},
  "peerDependencies": {
    "prettier": "^3.8.3",
    "react": "^19",
    "typescript": ">=5"
  },
  "devDependencies": {
    "@mpen/classcat": "workspace:*",
    "@mpen/ts-types": "workspace:*",
