{
    // Visit https://aka.ms/tsconfig to read more about this file
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "declaration": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "exactOptionalPropertyTypes": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "lib": [
            "ESNext",
            "es2015.iterable"
        ],
        "jsx": "react-jsx",
        "jsxImportSource": ".",
        "outDir": "./dist"
    },
    "files": [
        "./src/example.tsx"
    ],
    "include": [
        "./src/jsx.d.ts"
    ]
}
