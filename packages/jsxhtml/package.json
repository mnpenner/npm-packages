{
  "name": "@mpen/jsxhtml",
  "version": "0.5.2",
  "packageManager": "bun@1.3.7",
  "exports": {
    ".": "./dist/index.mjs",
    "./jsx-dev-runtime": "./dist/jsx-dev-runtime.mjs",
    "./jsx-runtime": "./dist/jsx-runtime.mjs",
    "./package.json": "./package.json"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "author": {
    "name": "Mark Penner",
    "email": "npm@mpen.ca",
    "url": "https://github.com/mnpenner"
  },
  "keywords": [
    "jsx",
    "tsx",
    "html",
    "render",
    "server",
    "ssr"
  ],
  "scripts": {
    "_dev:build": "tsdown --watch",
    "_dev:serve": "serve -l tcp://0.0.0.0:8080",
    "dev": "run-p \"dev:**\"",
    "dev:run": "NODE_ENV=production bun --watch run --jsx=react-jsx --jsx-import-source=. src/internal/dev.tsx",
    "dev:build": "NODE_ENV=production bun --watch --no-clear-screen build src/internal/dev.tsx --outdir=dist --packages=external --external '*'",
    "typecheck": "tsc --noEmit src/internal/dev.tsx --jsx react-jsx --jsxImportSource . --moduleResolution bundler --module esnext --lib dom,esnext --target esnext",
    "test:types": "tsc --noEmit && echo \"tsc: no errors\"",
    "test:unit": "NODE_ENV=production bun test --jsx-import-source=@mpen/jsxhtml",
    "test": "run-p 'test:*'",
    "build": "tsdown",
    "commit": "VER=$(jq -r '.version' package.json) && hg ci -m \"Commit v$VER\" && hg tag \"v$VER\"",
    "bumpver": "npm version patch",
    "release": "run-s test build bumpver commit && npm publish --access=public && hg pushall"
  },
  "devDependencies": {
    "@mpen/is-type": "workspace:*",
    "bun-types": "^1.2.15",
    "js-serialize": "workspace:*",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.10",
    "serve": "^14.2.4",
    "tsdown": "^0.21.10",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "csstype": "3.x"
  },
  "peerDependenciesMeta": {
    "elysia": {
      "optional": true
    },
    "csstype": {
      "optional": false
    }
  },
  "dependencies": {
    "@mpen/classcat": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
