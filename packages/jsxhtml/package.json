{
  "name": "@mpen/jsxhtml",
  "version": "0.2.0",
  "packageManager": "bun@1.2.9",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./jsx-runtime": {
      "import": "./dist/jsx-runtime.mjs",
      "require": "./dist/jsx-runtime.cjs",
      "types": "./dist/jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./dist/jsx-dev-runtime.mjs",
      "require": "./dist/jsx-dev-runtime.cjs",
      "types": "./dist/jsx-dev-runtime.d.ts"
    }
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "private": false,
  "sideEffects": false,
  "author": {
    "name": "Mark Penner",
    "email": "npm@mpen.ca",
    "url": "https://github.com/mnpenner"
  },
  "keywords": [
    "jsx",
    "html",
    "render",
    "server-side",
    "elysia"
  ],
  "scripts": {
    "dev:build": "rollup -cw",
    "_dev:serve": "serve -l tcp://0.0.0.0:8080",
    "dev": "run-p \"dev:**\"",
    "dev:serve": "bun run --hot src/dev.tsx",
    "test": "bun test",
    "bundle:clean": "rm -rf dist/",
    "bundle:build": "rollup -c",
    "bundle": "run-s bundle:clean bundle:build",
    "commit": "VER=$(jq -r '.version' package.json) && hg ci -m \"Commit v$VER\" && hg tag \"v$VER\"",
    "bumpver": "npm version patch",
    "release": "run-s test bundle bumpver commit && (cd dist && npm publish --access=public) && hg pushall",
    "lint": "sh -c 'eslint --quiet --fix --fix-type problem,suggestion,layout,directive -- \"${@:-.}\"' --"
  },
  "devDependencies": {
    "@mpen/is-type": "^0.1.15",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-replace": "^5.0.7",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/eslint": "^8.56.12",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "bun-types": "^1.2.9",
    "classnames": "^2.5.1",
    "csstype": "^3.1.3",
    "elysia": ">=1.2.25",
    "eslint": "^8.57.1",
    "eslint-plugin-react-compiler": "^19.0.0-beta-e993439-20250405",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "eslint-plugin-unused-imports": "^4.1.4",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.10",
    "rollup": "^4.40.0",
    "serve": "^14.2.4",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "elysia": ">=1.2.25"
  },
  "dependencies": {
    "classcat": "^5.0.5"
  }
}
