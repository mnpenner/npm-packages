{
  "name": "@mpen/react-external-state",
  "description": "Small external state stores with React hooks and localStorage persistence.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnpenner/npm-packages.git",
    "directory": "packages/react-external-state"
  },
  "license": "MIT",
  "author": "Mark Penner <npm@mpen.ca>",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.js",
    "./react": "./dist/react.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "build": "bun run --bun tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "_prepublishOnly": "bun run build && bun run test"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js"
}
