{
    "extends": "../../tsconfig.json",
    /* Visit https://aka.ms/tsconfig.json to read more about this file */
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ES2022",
        "declaration": true,
        "declarationDir": "./dist",
        "noEmitOnError": false,
        "emitDeclarationOnly": true,
        "outDir": "dist/",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "types": ["bun-types"]
    },
    "include": [
        "src/**/*.ts"
    ]
}
