{
  "name": "@mpen/server-router",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./helpers/zod": {
      "bun": "./src/helpers/zod/index.ts",
      "default": "./dist/helpers/zod.mjs"
    },
    "./lib/collections": {
      "bun": "./src/lib/collections.ts",
      "default": "./dist/lib/collections.mjs"
    },
    "./middleware": {
      "bun": "./src/middleware/index.ts",
      "default": "./dist/middleware.mjs"
    },
    "./plugins/openapi": {
      "bun": "./src/plugins/openapi/index.ts",
      "default": "./dist/plugins/openapi.mjs"
    },
    "./response": {
      "bun": "./src/response/index.ts",
      "default": "./dist/response.mjs"
    },
    "./response/simple": {
      "bun": "./src/response/simple.ts",
      "default": "./dist/response/simple.mjs"
    },
    "./routes": {
      "bun": "./src/routes/index.ts",
      "default": "./dist/routes.mjs"
    },
    "./testing/type-assert": {
      "bun": "./src/testing/type-assert.ts",
      "default": "./dist/testing/type-assert.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "server-router-gen-api-client": "./src/bin/gen-api-client.ts"
  },
  "files": [
    "src"
  ],
  "module": "./dist/index.mjs",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.18.1",
    "zod": "^4.3.5",
    "maxmind": "^5"
  },
  "peerDependencies": {
    "maxmind": "^5",
    "typescript": "^5",
    "zod": "^4.3.5"
  },
  "peerDependenciesMeta": {
    "maxmind": {
      "optional": true
    }
  },
  "dependencies": {
    "@mpen/http-helpers": "workspace:*",
    "chalk": "^5.6.2",
    "json-schema-to-typescript": "^15.0.4"
  },
  "scripts": {
    "build": "tsdown",
    "gen": "bun ./src/bin/gen-api-client.ts ./examples/router-instance.ts ./examples/api-client.gen.ts"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts"
}
