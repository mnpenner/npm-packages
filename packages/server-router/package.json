{
  "name": "@mpen/server-router",
  "description": "Typed server-side routing utilities for Fetch-compatible runtimes.",
  "exports": {
    ".": "./dist/index.mjs",
    "./client": "./dist/client.mjs",
    "./helpers/zod": "./dist/helpers/zod.mjs",
    "./lib/collections": "./dist/lib/collections.mjs",
    "./middleware": "./dist/middleware.mjs",
    "./plugins/openapi": "./dist/plugins/openapi.mjs",
    "./response": "./dist/response.mjs",
    "./response/simple": "./dist/response/simple.mjs",
    "./routes": "./dist/routes.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "server-router-gen-api-client": "./src/bin/gen-api-client.ts"
  },
  "files": [
    "src"
  ],
  "module": "./dist/index.mjs",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "catalog:",
    "zod": "^4.3.5",
    "@mpen/ts-types": "workspace:*",
    "maxmind": "^5"
  },
  "peerDependencies": {
    "maxmind": "^5",
    "typescript": "^5",
    "zod": "^4.3.5"
  },
  "peerDependenciesMeta": {
    "maxmind": {
      "optional": true
    }
  },
  "dependencies": {
    "@mpen/http-helpers": "workspace:*",
    "chalk": "^5.6.2",
    "json-schema-to-typescript": "^15.0.4"
  },
  "scripts": {
    "build": "tsdown",
    "gen": "bun ./src/bin/gen-api-client.ts ./examples/router-instance.ts -o ./examples/api-client.gen.ts",
    "gen3": "bun ./src/bin/gen-api-client.ts ./example3/router.ts -w -p"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  }
}
