{
    "name": "podman",
    "version": "0.3.1",
    "description": "Utilities for starting a Podman machine from Bun/Node.",
    "author": "Mark Penner <npm@mpen.ca>",
    "module": "index.ts",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "bun": "./src/index.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "license": "MIT",
    "engines": {
        "node": ">=18",
        "bun": ">=1.0"
    },
    "homepage": "https://github.com/mnpenner/npm-packages/tree/main/packages/podman",
    "repository": {
        "type": "git",
        "url": "https://github.com/mnpenner/npm-packages.git",
        "directory": "packages/podman"
    },
    "scripts": {
        "build": "bun run build.ts && tsc -p tsconfig.build.json"
    },
    "devDependencies": {},
    "peerDependencies": {
        "typescript": "^5.9.3"
    }
}
