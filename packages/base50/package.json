{
  "name": "@mpen/base50",
  "version": "0.2.2",
  "packageManager": "bun@1.2.10",
  "type": "module",
  "exports": {
    ".": "./dist/bundle.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/bundle.mjs",
  "module": "./dist/bundle.mjs",
  "types": "./dist/bundle.d.mts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/bun": "catalog:",
    "bun-types": "catalog:",
    "chalk": "catalog:",
    "mitata": "^1.0.34",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT",
  "scripts": {
    "test": "bun test --watch src",
    "dev": "bun run --hot src/dev.ts",
    "build": "tsdown",
    "patch": "npm version patch && VER=$(jq -r '.version' package.json) && hg ci -m \"Publish v$VER\" && hg tag \"v$VER\"",
    "release": "bun run build && bun run patch && npm publish --access=public && hg push"
  },
  "publishConfig": {
    "access": "public"
  }
}
