{
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "types": ["bun-types"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "outDir": "./dist"
  },
  "files": [
    "./serve.ts"
  ]
}
